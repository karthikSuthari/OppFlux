# ===========================================
# Opportunity Content Engine - Configuration
# ===========================================

# Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Sheets
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Image output directory (temporary before cloud upload)
IMAGE_OUTPUT_DIR=./images

# Logging
LOG_LEVEL=info

# Pipeline (runs every 60 minutes via PM2 cron)
POLL_INTERVAL_MINUTES=60
DRY_RUN=false

# Rate Limiting (delay between Gemini API calls in ms)
GEMINI_RATE_LIMIT_MS=1500

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Webhook Server
# Set WEBHOOK_URL to your public HTTPS URL (e.g., https://your-vm-ip or behind nginx)
WEBHOOK_URL=
WEBHOOK_PORT=3000
WEBHOOK_SECRET=change-this-to-a-random-string
